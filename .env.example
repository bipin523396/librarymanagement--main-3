# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=.onrender.com,.vercel.app,localhost,127.0.0.1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bookhub_db?retryWrites=true&w=majority
MONGODB_NAME=bookhub_db
DJANGO_DATABASE_URL=

# Deployment URLs (set on Render)
RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com
FRONTEND_URL=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=your-app.vercel.app,your-service.onrender.com

# Vercel only — must match your Render service URL in vercel.json rewrites
RENDER_BACKEND_URL=https://your-service.onrender.com
